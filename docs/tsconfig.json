{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "useDefineForClassFields": true,
        "baseUrl": ".",
        "paths": {
            "samsara": ["../src/index.ts"],
            "samsara/styles.css": ["../src/styles.css"],
            "react": ["./node_modules/@types/react"],
            "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime.d.ts"],
            "react-dom": ["./node_modules/@types/react-dom"],
            "react-dom/client": ["./node_modules/@types/react-dom/client.d.ts"],
            "@radix-ui/react-dialog": ["./node_modules/@radix-ui/react-dialog"],
            "@radix-ui/react-tooltip": ["./node_modules/@radix-ui/react-tooltip"],
            "@radix-ui/react-slot": ["./node_modules/@radix-ui/react-slot"]
        }
    },
    "include": ["src", "vite.config.ts", "../src"]
}
